{
  "name": "ai-test-case-generator-root",
  "version": "1.0.0",
  "description": "Privacy-First AI Test Case Generator — monorepo root dev scripts",
  "scripts": {
    "start:dev": "concurrently --kill-others --names \"FLASK,VITE\" --prefix-colors \"cyan,magenta\" \"python app.py\" \"npm run dev --prefix frontend\"",
    "build": "npm run build --prefix frontend",
    "install:all": "npm install && npm install --prefix frontend",
    "lint": "npm run lint --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
